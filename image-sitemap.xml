---
layout: null
permalink: /image-sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  <url>
    <loc>{{ site.url }}/talks</loc>
    {% for image in site.static_files %}
    {% if image.path contains 'assets/img/talks' and image.extname == '.jpg' %}
    <image:image>
      <image:loc>{{ site.url }}{{ image.path }}</image:loc>
      <image:title>Dr. Emre Süren, Royal Hacking Lab, {{ image.basename | replace: '-', ' ' }}</image:title>
    </image:image>
    {% endif %}
    {% endfor %}
  </url>
</urlset>
